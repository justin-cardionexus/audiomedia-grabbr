# Copy to .env and fill in. The Reflex app reads these at runtime.

# --- LLM (Claude) ---
# Required. Used to turn transcripts into per-segment visual search queries.
ANTHROPIC_API_KEY=sk-ant-...

# --- Media search (stock APIs) ---
# Required. Free keys:
#   Pexels:  https://www.pexels.com/api/
#   Pixabay: https://pixabay.com/api/docs/
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- Google sign-in (OAuth) ---
# Optional. Create an OAuth 2.0 Client (type: Web application) at
# https://console.cloud.google.com/apis/credentials and add this authorized
# redirect URI: http://localhost:8000/auth/google/callback
# The "Sign in with Google" button activates once both values are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional overrides if not running on the default localhost ports:
# FRONTEND_URL=http://localhost:3000
# BACKEND_URL=http://localhost:8000
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Passwordless email sign-in (SMTP) ---
# Optional. Set all three to enable the "Email me a sign-in link" option on the
# login page. Use your mail provider's SMTP credentials (e.g. an app password).
SMTP_HOSTNAME=
SMTP_USERNAME=
SMTP_PASSWORD=
# Optional SMTP tuning:
# SMTP_PORT=587                 # 587 (STARTTLS, default) or 465 (set STARTTLS=false)
# SMTP_STARTTLS=true            # set "false" for an SSL-on-connect port like 465
# SMTP_FROM=AudioMedia <no-reply@example.com>   # defaults to SMTP_USERNAME
# MAGIC_LINK_TTL_MINUTES=15

# --- Custom domains (deployment only — read by deploy.sh, not the app) ---
# Optional. Public custom domains CNAME'd to the fly.dev URLs. Bare host or full
# URL accepted. When unset, deploy.sh uses the fly.dev-assigned URLs.
#   - FRONTEND_DOMAIN: where users load the app (e.g. app.example.com)
#   - BACKEND_DOMAIN:  branded OAuth/magic-link URLs (e.g. api.example.com)
# deploy.sh provisions Fly TLS certs for these and wires the env/build args.
# The browser SPA always connects to the fly.dev backend; CORS allows both the
# custom and fly.dev frontend origins. (Distinct from the app's FRONTEND_URL/
# BACKEND_URL above, which the app reads at runtime for local dev.)
# FRONTEND_DOMAIN=app.example.com
# BACKEND_DOMAIN=api.example.com

# --- Database ---
# Optional. Defaults to local SQLite (sqlite:///reflex.db) when unset.
# For production, point at Postgres, e.g.:
#   DATABASE_URL=postgresql://user:pass@localhost:5432/audiomedia
# DATABASE_URL=

# --- Transcription (faster-whisper) ---
# Optional. Model size: tiny | base | small | medium | large-v3 (default: base).
# Larger = more accurate but slower; downloaded on first run.
# WHISPER_MODEL_SIZE=base

# Optional. A Hugging Face access token silences the "unauthenticated requests
# to the HF Hub" warning during model download and grants higher rate limits.
# Create one at https://huggingface.co/settings/tokens (read scope is enough).
# HF_TOKEN=hf_...
